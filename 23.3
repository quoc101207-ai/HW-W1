import folium
from folium.plugins import HeatMap
import pandas as pd

# 1. Chuẩn bị dữ liệu (Giả sử đây là tọa độ các kho/điểm nhận hàng tại TP.HCM)
# Cấu trúc: [vĩ độ, kinh độ, trọng số/độ lớn]
data = [
    [10.7827, 106.6944, 0.9],  # Quận 3
    [10.7725, 106.6980, 0.8],  # Quận 1
    [10.7950, 106.7219, 1.2],  # Bình Thạnh (Điểm nóng)
    [10.8266, 106.6633, 0.7],  # Gò Vấp
    [10.7599, 106.6822, 0.6],  # Quận 5
    [10.7324, 106.7018, 1.5],  # Quận 7 (Điểm rất nóng)
    [10.8510, 106.7720, 1.1],  # Thủ Đức
    [10.7750, 106.6667, 0.5],  # Quận 10
    [10.7630, 106.6500, 0.4],  # Quận 11
    [10.8000, 106.6450, 0.9]   # Tân Bình
]

# 2. Khởi tạo bản đồ tại trung tâm TP.HCM
m = folium.Map(location=[10.7769, 106.7009], zoom_start=12)

# 3. Thêm lớp HeatMap
# min_opacity: độ trong suốt tối thiểu
# radius: bán kính ảnh hưởng của mỗi điểm (tính bằng pixel)
HeatMap(data, min_opacity=0.4, radius=25, blur=15).add_to(m)

# 4. Thêm các Marker để dễ đối chiếu (Tùy chọn)
for point in data:
    folium.CircleMarker(
        location=[point[0], point[1]],
        radius=2,
        color='black',
        fill=True
    ).add_to(m)

m
